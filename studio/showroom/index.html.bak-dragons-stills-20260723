<style>
  :root{
    --bg:#08090e; --panel:#12141c; --panel2:#171a24;
    --gold:#d8b46a; --gold-bright:#f0d68a; --gold-dim:rgba(216,180,106,.4);
    --ink:#f3edd9; --muted:#a9a290;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{background:var(--bg);color:var(--ink);font-family:'EB Garamond',serif;line-height:1.6;overflow-x:hidden}
  .wrap{max-width:1180px;margin:0 auto;padding:0 22px}
  h1,h2,h3{font-family:'Cinzel Decorative',serif;font-weight:900;letter-spacing:.5px;line-height:1.15}
  .eyebrow{font-family:'Cinzel',serif;font-size:12px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);font-weight:600}
  .previewbar{background:linear-gradient(90deg,#2a2010,#171a24);border-bottom:1px solid var(--gold-dim);color:var(--gold-bright);font-family:'Cinzel',serif;font-size:11px;letter-spacing:2px;text-transform:uppercase;text-align:center;padding:8px 12px}

  .hero{position:relative;height:82vh;min-height:520px;display:flex;align-items:flex-end;overflow:hidden}
  .hero video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0}
  .hero .veil{position:absolute;inset:0;z-index:1;background:
     radial-gradient(ellipse 90% 70% at 50% 30%,transparent 0%,rgba(8,9,14,.35) 70%,rgba(8,9,14,.9) 100%),
     linear-gradient(180deg,rgba(8,9,14,.55) 0%,transparent 30%,rgba(8,9,14,.85) 100%)}
  .hero-inner{position:relative;z-index:2;padding-bottom:54px}
  .hero h1{font-size:clamp(34px,6vw,68px);color:var(--gold-bright);text-shadow:0 4px 40px rgba(0,0,0,.8)}
  .hero p{font-size:clamp(16px,2.2vw,22px);color:var(--ink);max-width:640px;margin-top:16px;text-shadow:0 2px 20px rgba(0,0,0,.9)}
  .hero .eyebrow{margin-bottom:16px}

  section.block{padding:74px 0 20px}
  .sec-head{text-align:center;max-width:760px;margin:0 auto 40px}
  .sec-head h2{font-size:clamp(26px,3.5vw,40px);color:var(--gold-bright);margin:14px 0 12px}
  .sec-head p{color:var(--muted);font-size:17px}

  .grid{display:grid;gap:18px}
  .grid.reveals{grid-template-columns:repeat(6,1fr)}
  @media(max-width:980px){.grid.reveals{grid-template-columns:repeat(3,1fr)}}
  @media(max-width:600px){.grid.reveals{grid-template-columns:repeat(2,1fr)}}
  .card{position:relative;border-radius:14px;overflow:hidden;background:var(--panel);
        border:1px solid rgba(216,180,106,.18);box-shadow:0 16px 40px -20px rgba(0,0,0,.8);
        transition:transform .3s ease,border-color .3s ease}
  .card:hover{transform:translateY(-4px);border-color:var(--gold-dim)}
  .card video{display:block;width:100%;height:100%;object-fit:cover;background:#000}
  .card.portrait video{aspect-ratio:9/16}
  .card.land video{aspect-ratio:16/9}
  .card.tall video{aspect-ratio:3/4}
  .card .label{position:absolute;left:0;right:0;bottom:0;padding:26px 12px 12px;
        font-family:'Cinzel',serif;font-size:12px;letter-spacing:1.2px;text-transform:uppercase;color:var(--ink);
        background:linear-gradient(0deg,rgba(6,7,12,.92) 0%,transparent 100%);pointer-events:none}

  /* STORY */
  .feature{border-radius:16px;overflow:hidden;border:1px solid rgba(216,180,106,.2);box-shadow:0 20px 50px -24px rgba(0,0,0,.85);position:relative}
  .feature video{display:block;width:100%;aspect-ratio:16/9;object-fit:cover;background:#000}
  .feature .label{position:absolute;left:0;right:0;bottom:0;padding:34px 18px 14px;font-family:'Cinzel',serif;font-size:13px;letter-spacing:1.4px;text-transform:uppercase;color:var(--ink);background:linear-gradient(0deg,rgba(6,7,12,.92),transparent)}
  .transform{display:flex;gap:14px;align-items:center;justify-content:center;margin-top:26px;flex-wrap:wrap}
  .transform .t-card{position:relative;flex:0 1 300px;border-radius:14px;overflow:hidden;border:1px solid rgba(216,180,106,.2);background:#000}
  .transform .t-card video{display:block;width:100%;aspect-ratio:3/4;object-fit:cover;background:#000}
  .transform .t-card .label{position:absolute;left:0;right:0;bottom:0;padding:24px 12px 10px;font-family:'Cinzel',serif;font-size:12px;letter-spacing:1.2px;text-transform:uppercase;background:linear-gradient(0deg,rgba(6,7,12,.92),transparent)}
  .arrow{font-family:'Cinzel',serif;color:var(--gold);font-size:34px;line-height:1}
  @media(max-width:680px){.arrow{transform:rotate(90deg)}}

  .pack{margin:60px 0 10px;background:linear-gradient(150deg,var(--panel2) 0%,var(--panel) 100%);
        border:1px solid var(--gold-dim);border-radius:18px;padding:34px;display:flex;gap:30px;align-items:center;flex-wrap:wrap}
  .pack .thumb{flex:0 0 240px;max-width:100%;border-radius:12px;overflow:hidden;border:1px solid rgba(216,180,106,.25)}
  .pack .thumb video{display:block;width:100%;aspect-ratio:9/16;object-fit:cover;background:#000}
  .pack .body{flex:1;min-width:260px}
  .pack h3{font-size:24px;color:var(--gold-bright);margin-bottom:10px}
  .pack p{color:var(--muted);margin-bottom:18px}
  .btn{display:inline-block;font-family:'Cinzel',serif;font-size:13px;letter-spacing:1.5px;text-transform:uppercase;
       padding:13px 26px;border-radius:10px;background:linear-gradient(180deg,var(--gold-bright),var(--gold));
       color:#1a140a;font-weight:600;text-decoration:none;box-shadow:0 8px 24px -8px rgba(216,180,106,.5);transition:transform .2s}
  .btn:hover{transform:translateY(-2px)}
  .btn.ghost{background:none;color:var(--gold);border:1px solid var(--gold-dim);box-shadow:none}

  .cta{text-align:center;padding:86px 0 40px}
  .cta h2{font-size:clamp(28px,4vw,46px);color:var(--gold-bright);margin-bottom:18px}
  .cta p{font-size:19px;color:var(--muted);max-width:600px;margin:0 auto 28px}

  footer{border-top:1px solid rgba(216,180,106,.15);margin-top:40px;padding:30px 0 60px;text-align:center;color:var(--muted);font-size:14px}
  footer a{color:var(--gold);text-decoration:none}
  footer .disc{font-size:12.5px;opacity:.7;margin-top:12px;font-style:italic}

  .locgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
  @media(max-width:820px){.locgrid{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:520px){.locgrid{grid-template-columns:1fr}}
  .loc{position:relative;border-radius:12px;overflow:hidden;border:1px solid rgba(216,180,106,.18);background:#000;transition:transform .3s,border-color .3s}
  .loc:hover{transform:translateY(-4px);border-color:var(--gold-dim)}
  .loc img{display:block;width:100%;aspect-ratio:16/9;object-fit:cover}
  .loc .label{position:absolute;left:0;right:0;bottom:0;padding:22px 12px 9px;font-family:'Cinzel',serif;font-size:11.5px;letter-spacing:1.2px;text-transform:uppercase;color:var(--ink);background:linear-gradient(0deg,rgba(6,7,12,.9),transparent);pointer-events:none}

  #lb{position:fixed;inset:0;z-index:999;display:none;align-items:center;justify-content:center;background:rgba(4,5,9,.93);backdrop-filter:blur(4px);cursor:zoom-out;padding:24px}
  #lb.open{display:flex}
  #lb .media{max-width:92vw;max-height:90vh;border-radius:10px;border:1px solid rgba(216,180,106,.3);box-shadow:0 30px 80px -20px #000;cursor:default;background:#000}
  #lb .close{position:fixed;top:16px;right:24px;color:var(--gold);font-family:'Cinzel',serif;font-size:24px;cursor:pointer;line-height:1;z-index:1000;opacity:.85}
  #lb .close:hover{opacity:1}
  .card,.feature,.loc{cursor:zoom-in}
  .hint{text-align:center;color:var(--muted);font-family:'Cinzel',serif;font-size:11px;letter-spacing:2px;text-transform:uppercase;padding:30px 0 0;opacity:.7}
  .pingrid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
  @media(max-width:820px){.pingrid{grid-template-columns:repeat(2,1fr)}}
  .pin{position:relative;border-radius:12px;overflow:hidden;border:1px solid rgba(216,180,106,.16);background:#000;display:block;transition:transform .25s,border-color .25s}
  .pin:hover{transform:translateY(-4px);border-color:var(--gold-dim)}
  .pin img{display:block;width:100%;aspect-ratio:2/3;object-fit:cover}
  .brandbar{position:absolute;top:20px;left:26px;z-index:5;display:flex;align-items:center;gap:11px;text-decoration:none}
  .brandbar img{width:46px;height:46px;border-radius:50%;box-shadow:0 0 24px rgba(216,180,106,.35)}
  .brandbar span{font-family:'Cinzel Decorative',serif;font-weight:900;letter-spacing:3px;font-size:18px;color:var(--ink);text-shadow:0 2px 16px rgba(0,0,0,.85)}
  @media(max-width:560px){.brandbar span{display:none}}
  .grid.classics{grid-template-columns:repeat(4,1fr)}
  @media(max-width:820px){.grid.classics{grid-template-columns:repeat(2,1fr)}}
  .feature.dragon video{aspect-ratio:4/3}
  .grid.archetypes{grid-template-columns:repeat(3,1fr);max-width:820px;margin:0 auto}
  @media(max-width:600px){.grid.archetypes{grid-template-columns:repeat(2,1fr);max-width:none}}
  .grid.souls{grid-template-columns:repeat(3,1fr);gap:14px}
  @media(max-width:900px){.grid.souls{grid-template-columns:repeat(3,1fr)}}
  @media(max-width:560px){.grid.souls{grid-template-columns:repeat(2,1fr)}}
  .souls .card video,.souls .card .img{aspect-ratio:2/3}

  /* DRAGONS STRIP */
  .dragstrip{display:flex;gap:10px;overflow-x:auto;padding-bottom:8px;scrollbar-width:thin}
  .dragstrip .drag{position:relative;flex:0 0 150px;border-radius:10px;overflow:hidden;border:1px solid rgba(216,180,106,.18);background:var(--panel);transition:border-color .25s}
  .dragstrip .drag:hover{border-color:var(--gold-dim)}
  .dragstrip .drag video{display:block;width:100%;aspect-ratio:3/4;object-fit:cover;background:#000}
  .dragstrip .drag .dl{position:absolute;left:0;right:0;bottom:0;padding:14px 8px 6px;font-family:'Cinzel',serif;font-size:10.5px;letter-spacing:1px;text-transform:uppercase;color:var(--ink);background:linear-gradient(0deg,rgba(6,7,12,.92),transparent);pointer-events:none}
  @media(max-width:520px){.dragstrip .drag{flex:0 0 128px}}
</style>
</head>
