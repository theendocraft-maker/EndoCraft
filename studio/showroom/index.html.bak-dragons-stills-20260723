    return d;
  }
  var rw=document.getElementById('reveals'); REVEALS.forEach(function(r){rw.appendChild(card(r[0],r[1],r[2]));});

  var io=new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      var v=e.target;
      if(e.isIntersecting){
        if(!v.dataset.loaded){var s=document.createElement('source');s.src=v.dataset.lazy;s.type='video/mp4';v.appendChild(s);v.load();v.dataset.loaded='1';}
        v.play().catch(function(){});
      } else { v.pause(); }
    });
  },{rootMargin:'200px 0px',threshold:0.25});
  document.querySelectorAll('video[data-lazy]').forEach(function(v){io.observe(v);});
</script>

<div id="lb"><span class="close" id="lbClose">&#10005;</span></div>
<script>
(function(){
  var lb=document.getElementById('lb'), closeBtn=document.getElementById('lbClose');
  function clear(){ lb.querySelectorAll('.media').forEach(function(m){ if(m.tagName==='VIDEO'){try{m.pause();}catch(e){}} m.remove(); }); }
  function openEl(el){
    clear();
    var v=el.querySelector('video'), img=el.querySelector('img'), media;
    if(v){
      var s=v.dataset.lazy || (v.querySelector('source')&&v.querySelector('source').getAttribute('src'));
      if(!s) return;
      media=document.createElement('video'); media.className='media'; media.src=s;
      media.controls=true; media.autoplay=true; media.loop=true; media.playsInline=true; media.setAttribute('playsinline','');
    } else if(img){
      media=document.createElement('img'); media.className='media'; media.src=img.src;
    } else { return; }
    lb.appendChild(media); lb.classList.add('open');
  }
  function close(){ lb.classList.remove('open'); clear(); }
  document.querySelectorAll('.card, .feature, .loc').forEach(function(el){ el.addEventListener('click', function(){ openEl(el); }); });
  lb.addEventListener('click', function(e){ if(e.target===lb) close(); });
  closeBtn.addEventListener('click', close);
  document.addEventListener('keydown', function(e){ if(e.key==='Escape') close(); });
})();
</script>

