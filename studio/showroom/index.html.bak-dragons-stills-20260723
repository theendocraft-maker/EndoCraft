<script>
/* self-heal: if an image ever loads broken (stale/partial CDN or browser cache),
   re-fetch it once with a cache-buster so no visitor gets stranded on a blank tile */
(function(){
  function heal(img){
    if(img.dataset.healed) return;
    img.dataset.healed='1';
    var base=img.src.split('?')[0];
    img.src=base+(base.indexOf('?')>-1?'&':'?')+'r='+Date.now();
  }
  document.querySelectorAll('img').forEach(function(img){
    img.addEventListener('error',function(){heal(img);});
    img.addEventListener('load',function(){ if(img.naturalWidth===0) heal(img); });
    if(img.complete && img.naturalWidth===0 && img.src) heal(img);
  });
})();
</script>
